<Window
    x:Class="BeatingQueensGambit.UI.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:BeatingQueensGambit.UI.ViewModels"
    x:DataType="viewModels:ChessViewModel"
    Width="1500"
    Height="980"
    Title="Beating Queen's Gambit">

    <Grid ColumnDefinitions="3*,1*">

        <!-- ====================================================== -->
        <!-- BOARD AREA -->
        <!-- ====================================================== -->

        <Grid
            Grid.Column="0"
            Margin="20"
            RowDefinitions="Auto,*,Auto"
            ColumnDefinitions="Auto,*,Auto">

            <!-- Top Coordinates -->

            <UniformGrid
                Grid.Row="0"
                Grid.Column="1"
                Columns="8"
                Margin="16,0,16,8">

                <TextBlock Text="A" HorizontalAlignment="Center" FontSize="22"/>
                <TextBlock Text="B" HorizontalAlignment="Center" FontSize="22"/>
                <TextBlock Text="C" HorizontalAlignment="Center" FontSize="22"/>
                <TextBlock Text="D" HorizontalAlignment="Center" FontSize="22"/>
                <TextBlock Text="E" HorizontalAlignment="Center" FontSize="22"/>
                <TextBlock Text="F" HorizontalAlignment="Center" FontSize="22"/>
                <TextBlock Text="G" HorizontalAlignment="Center" FontSize="22"/>
                <TextBlock Text="H" HorizontalAlignment="Center" FontSize="22"/>

            </UniformGrid>

            <!-- Left Coordinates -->

            <UniformGrid
                Grid.Row="1"
                Grid.Column="0"
                Rows="8"
                Margin="0,10">

                <TextBlock Text="8" VerticalAlignment="Center" FontSize="22"/>
                <TextBlock Text="7" VerticalAlignment="Center" FontSize="22"/>
                <TextBlock Text="6" VerticalAlignment="Center" FontSize="22"/>
                <TextBlock Text="5" VerticalAlignment="Center" FontSize="22"/>
                <TextBlock Text="4" VerticalAlignment="Center" FontSize="22"/>
                <TextBlock Text="3" VerticalAlignment="Center" FontSize="22"/>
                <TextBlock Text="2" VerticalAlignment="Center" FontSize="22"/>
                <TextBlock Text="1" VerticalAlignment="Center" FontSize="22"/>

            </UniformGrid>

            <!-- Chess Board -->

            <Border
                Grid.Row="1"
                Grid.Column="1"
                Margin="8"
                Padding="8"
                Background="#252525"
                BorderBrush="#404040"
                BorderThickness="3"
                CornerRadius="8">

                <ItemsControl ItemsSource="{Binding Squares}">

                    <ItemsControl.ItemsPanel>

                        <ItemsPanelTemplate>

                            <UniformGrid
                                Rows="8"
                                Columns="8"/>

                        </ItemsPanelTemplate>

                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>

                        <DataTemplate
                            x:DataType="viewModels:SquareViewModel">

                            <Border
                                Background="{Binding SquareColor}"
                                PointerPressed="SquarePressed">

                                <Image
                                    Margin="8"
                                    Stretch="Uniform"
                                    Source="{Binding PieceImage}"/>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </Border>

            <!-- Right Coordinates -->

            <UniformGrid
                Grid.Row="1"
                Grid.Column="2"
                Rows="8"
                Margin="0,10">

                <TextBlock Text="8" VerticalAlignment="Center" FontSize="22"/>
                <TextBlock Text="7" VerticalAlignment="Center" FontSize="22"/>
                <TextBlock Text="6" VerticalAlignment="Center" FontSize="22"/>
                <TextBlock Text="5" VerticalAlignment="Center" FontSize="22"/>
                <TextBlock Text="4" VerticalAlignment="Center" FontSize="22"/>
                <TextBlock Text="3" VerticalAlignment="Center" FontSize="22"/>
                <TextBlock Text="2" VerticalAlignment="Center" FontSize="22"/>
                <TextBlock Text="1" VerticalAlignment="Center" FontSize="22"/>

            </UniformGrid>

            <!-- Bottom Coordinates -->

            <UniformGrid
                Grid.Row="2"
                Grid.Column="1"
                Columns="8"
                Margin="16,8,16,0">

                <TextBlock Text="A" HorizontalAlignment="Center" FontSize="22"/>
                <TextBlock Text="B" HorizontalAlignment="Center" FontSize="22"/>
                <TextBlock Text="C" HorizontalAlignment="Center" FontSize="22"/>
                <TextBlock Text="D" HorizontalAlignment="Center" FontSize="22"/>
                <TextBlock Text="E" HorizontalAlignment="Center" FontSize="22"/>
                <TextBlock Text="F" HorizontalAlignment="Center" FontSize="22"/>
                <TextBlock Text="G" HorizontalAlignment="Center" FontSize="22"/>
                <TextBlock Text="H" HorizontalAlignment="Center" FontSize="22"/>

            </UniformGrid>

        </Grid>

        <!-- ====================================================== -->
        <!-- RIGHT DASHBOARD -->
        <!-- ====================================================== -->

        <ScrollViewer
            Grid.Column="1"
            Margin="20">

            <StackPanel Spacing="20">

                <TextBlock
                    FontSize="30"
                    FontWeight="Bold"
                    Text="Beating Queen's Gambit"/>

                <!-- Game Information -->

                <Border
                    Background="#2E2E2E"
                    CornerRadius="8"
                    Padding="16">

                    <StackPanel Spacing="12">

                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="Current Turn"/>

                        <Border
                            Background="#404040"
                            CornerRadius="6"
                            Padding="10">

                            <TextBlock
                                FontSize="22"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="{Binding CurrentTurnText}"/>

                        </Border>

                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="Game Status"/>

                        <Border
                            Background="#404040"
                            CornerRadius="6"
                            Padding="10">

                            <TextBlock
                                FontWeight="Bold"
                                Foreground="White"
                                Text="{Binding GameStatusText}"/>

                        </Border>

                    </StackPanel>

                </Border>

                <!-- Move Information -->

                <Border
                    Background="#2E2E2E"
                    CornerRadius="8"
                    Padding="16">

                    <StackPanel Spacing="12">

                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="Selected Square"/>

                        <Border
                            Background="#404040"
                            CornerRadius="6"
                            Padding="10">

                            <TextBlock
                                Foreground="White"
                                Text="{Binding SelectedSquareText}"/>

                        </Border>

                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="Last Move"/>

                        <Border
                            Background="#404040"
                            CornerRadius="6"
                            Padding="10">

                            <TextBlock
                                Foreground="White"
                                Text="{Binding LastMoveText}"/>

                        </Border>

                    </StackPanel>

                </Border>

                <!-- Move History -->

                <Border
                    Background="#2E2E2E"
                    CornerRadius="8"
                    Padding="16">

                    <StackPanel>

                        <TextBlock
                            Margin="0,0,0,10"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="Move History"/>

                        <Border
                            Height="260"
                            Background="#404040"
                            CornerRadius="6"
                            Padding="10">

                            <ScrollViewer>

                                <ItemsControl ItemsSource="{Binding MoveHistory}">

                                    <ItemsControl.ItemTemplate>

                                        <DataTemplate>

                                            <TextBlock
                                                Margin="0,3"
                                                FontFamily="Consolas"
                                                FontSize="16"
                                                Foreground="White"
                                                Text="{Binding}"/>

                                        </DataTemplate>

                                    </ItemsControl.ItemTemplate>

                                </ItemsControl>

                            </ScrollViewer>

                        </Border>

                    </StackPanel>

                </Border>

                <Button
                    Width="220"
                    Height="54"
                    HorizontalAlignment="Center"
                    FontSize="20"
                    FontWeight="Bold"
                    Content="Restart Game"
                    Click="RestartGameClicked"/>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</Window>