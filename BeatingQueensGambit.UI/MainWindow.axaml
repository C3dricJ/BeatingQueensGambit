<Window
    x:Class="BeatingQueensGambit.UI.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:BeatingQueensGambit.UI.ViewModels"
    x:DataType="viewModels:ChessViewModel"
    Width="1050"
    Height="900"
    Title="Beating Queen's Gambit">

    <Grid
        ColumnDefinitions="850,*"
        RowDefinitions="*">

        <!-- ========================= -->
        <!-- Chess Board -->
        <!-- ========================= -->

    <Border
        Grid.Column="0"
        Width="800"
        Height="800"
        Margin="20"
        BorderBrush="#2E2E2E"
        BorderThickness="2"
        CornerRadius="6"
        ClipToBounds="True"
        HorizontalAlignment="Left"
        VerticalAlignment="Top">

        <ItemsControl ItemsSource="{Binding Squares}">

            <ItemsControl.ItemsPanel>

                <ItemsPanelTemplate>

                    <UniformGrid
                        Rows="8"
                        Columns="8"/>

                </ItemsPanelTemplate>

            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>

                <DataTemplate
                    x:DataType="viewModels:SquareViewModel">

                    <Border
                        Width="100"
                        Height="100"
                        Background="{Binding SquareColor}"
                        PointerPressed="SquarePressed">

                        <Image
                            Width="72"
                            Height="72"
                            Source="{Binding PieceImage}"
                            Stretch="Uniform"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                    </Border>

                </DataTemplate>

            </ItemsControl.ItemTemplate>

        </ItemsControl>

    </Border>

        <!-- ========================= -->
        <!-- Side Panel -->
        <!-- ========================= -->

        <StackPanel
            Grid.Column="1"
            Margin="20"
            Spacing="12">

            <TextBlock
                FontSize="28"
                FontWeight="Bold"
                Text="Beating Queen's Gambit"/>

            <Separator/>

            <TextBlock
                FontSize="18"
                Text="Current Turn"/>

            <Border
                Padding="10"
                CornerRadius="6"
                Background="#404040">

                <TextBlock
                    FontSize="22"
                    Foreground="White"
                    Text="Black"/>

            </Border>

            <Separator/>

            <TextBlock
                FontSize="18"
                Text="Selected Square"/>

            <Border
                Padding="10"
                CornerRadius="6"
                Background="#404040">

                <TextBlock
                    Foreground="White"
                    Text="{Binding SelectedSquareText}"/>

            </Border>

            <Separator/>

            <TextBlock
                FontSize="18"
                Text="Last Move"/>

            <Border
                Padding="10"
                CornerRadius="6"
                Background="#404040">

                <TextBlock
                    Foreground="White"
                    Text="None"/>

            </Border>

            <Separator/>

            <Button
                Width="180"
                Height="48"
                FontSize="18"
                FontWeight="Bold"
                Content="Restart Game"/>

        </StackPanel>

    </Grid>

</Window>