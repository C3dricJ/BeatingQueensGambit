<Window
    x:Class="BeatingQueensGambit.UI.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:BeatingQueensGambit.UI.ViewModels"
    x:DataType="viewModels:ChessViewModel"
    Width="1500"
    Height="980"
    Title="Beating Queen's Gambit">

    <Grid ColumnDefinitions="3*,1*">

        <!-- ====================================== -->
        <!-- BOARD AREA -->
        <!-- ====================================== -->

        <Grid
            Grid.Column="0"
            Margin="20"
            RowDefinitions="Auto,*,Auto"
            ColumnDefinitions="Auto,*,Auto">

            <!-- Top Letters -->

            <UniformGrid
                Grid.Row="0"
                Grid.Column="1"
                Columns="8"
                Margin="12,0">

                <TextBlock Text="A" HorizontalAlignment="Center"/>
                <TextBlock Text="B" HorizontalAlignment="Center"/>
                <TextBlock Text="C" HorizontalAlignment="Center"/>
                <TextBlock Text="D" HorizontalAlignment="Center"/>
                <TextBlock Text="E" HorizontalAlignment="Center"/>
                <TextBlock Text="F" HorizontalAlignment="Center"/>
                <TextBlock Text="G" HorizontalAlignment="Center"/>
                <TextBlock Text="H" HorizontalAlignment="Center"/>

            </UniformGrid>

            <!-- Left Numbers -->

            <UniformGrid
                Grid.Row="1"
                Grid.Column="0"
                Rows="8">

                <TextBlock Text="8" VerticalAlignment="Center"/>
                <TextBlock Text="7" VerticalAlignment="Center"/>
                <TextBlock Text="6" VerticalAlignment="Center"/>
                <TextBlock Text="5" VerticalAlignment="Center"/>
                <TextBlock Text="4" VerticalAlignment="Center"/>
                <TextBlock Text="3" VerticalAlignment="Center"/>
                <TextBlock Text="2" VerticalAlignment="Center"/>
                <TextBlock Text="1" VerticalAlignment="Center"/>

            </UniformGrid>

            <!-- Chess Board -->

            <Border
                Grid.Row="1"
                Grid.Column="1"
                Margin="8"
                Padding="8"
                Background="#252525"
                BorderBrush="#404040"
                BorderThickness="3"
                CornerRadius="8">

                <ItemsControl ItemsSource="{Binding Squares}">

                    <ItemsControl.ItemsPanel>

                        <ItemsPanelTemplate>

                            <UniformGrid
                                Rows="8"
                                Columns="8"/>

                        </ItemsPanelTemplate>

                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>

                        <DataTemplate
                            x:DataType="viewModels:SquareViewModel">

                            <Border
                                Background="{Binding SquareColor}"
                                PointerPressed="SquarePressed">

                                <Image
                                    Margin="8"
                                    Stretch="Uniform"
                                    Source="{Binding PieceImage}"/>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </Border>

            <!-- Right Numbers -->

            <UniformGrid
                Grid.Row="1"
                Grid.Column="2"
                Rows="8">

                <TextBlock Text="8" VerticalAlignment="Center"/>
                <TextBlock Text="7" VerticalAlignment="Center"/>
                <TextBlock Text="6" VerticalAlignment="Center"/>
                <TextBlock Text="5" VerticalAlignment="Center"/>
                <TextBlock Text="4" VerticalAlignment="Center"/>
                <TextBlock Text="3" VerticalAlignment="Center"/>
                <TextBlock Text="2" VerticalAlignment="Center"/>
                <TextBlock Text="1" VerticalAlignment="Center"/>

            </UniformGrid>

            <!-- Bottom Letters -->

            <UniformGrid
                Grid.Row="2"
                Grid.Column="1"
                Columns="8"
                Margin="12,0">

                <TextBlock Text="A" HorizontalAlignment="Center"/>
                <TextBlock Text="B" HorizontalAlignment="Center"/>
                <TextBlock Text="C" HorizontalAlignment="Center"/>
                <TextBlock Text="D" HorizontalAlignment="Center"/>
                <TextBlock Text="E" HorizontalAlignment="Center"/>
                <TextBlock Text="F" HorizontalAlignment="Center"/>
                <TextBlock Text="G" HorizontalAlignment="Center"/>
                <TextBlock Text="H" HorizontalAlignment="Center"/>

            </UniformGrid>

        </Grid>

        <!-- ====================================== -->
        <!-- KEEP YOUR CURRENT RIGHT DASHBOARD HERE -->
        <!-- ====================================== -->

        <ScrollViewer
            Grid.Column="1"
            Margin="20">

            <!-- Copy your existing dashboard here unchanged -->

        </ScrollViewer>

    </Grid>

</Window>