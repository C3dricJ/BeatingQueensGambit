<Window
    x:Class="BeatingQueensGambit.UI.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:BeatingQueensGambit.UI.ViewModels"
    x:DataType="viewModels:ChessViewModel"
    Width="1450"
    Height="980"
    Title="Beating Queen's Gambit">

    <Grid
        ColumnDefinitions="3*,1*"
        RowDefinitions="*">

        <!-- ========================= -->
        <!-- Chess Board -->
        <!-- ========================= -->

    <Border
        Grid.Column="0"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Margin="30"
        Padding="8"
        BorderBrush="#404040"
        BorderThickness="3"
        CornerRadius="8"
        Background="#252525">

        <ItemsControl ItemsSource="{Binding Squares}">

            <ItemsControl.ItemsPanel>

                <ItemsPanelTemplate>

                    <UniformGrid
                        Rows="8"
                        Columns="8"/>

                </ItemsPanelTemplate>

            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>

                <DataTemplate
                    x:DataType="viewModels:SquareViewModel">

                    <Border
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="{Binding SquareColor}"
                        PointerPressed="SquarePressed">

                        <Image
                            Margin="10"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Source="{Binding PieceImage}"
                            Stretch="Uniform"/>

                    </Border>

                </DataTemplate>

            </ItemsControl.ItemTemplate>

        </ItemsControl>

    </Border>

        <!-- ========================= -->
        <!-- Side Panel -->
        <!-- ========================= -->

        <StackPanel
            Grid.Column="1"
            Margin="20"
            Spacing="12">

            <TextBlock
                FontSize="28"
                FontWeight="Bold"
                Text="Beating Queen's Gambit"/>

            <Separator/>

            <TextBlock
                FontSize="18"
                Text="Current Turn"/>

            <Border
                Padding="10"
                CornerRadius="6"
                Background="#404040">

                <TextBlock
                    FontSize="22"
                    Foreground="White"
                    FontWeight="Bold"
                    Text="{Binding CurrentTurnText}"/>

            </Border>

            <Separator/>

            <TextBlock
                FontSize="18"
                Text="Selected Square"/>

            <Border
                Padding="10"
                CornerRadius="6"
                Background="#404040">

                <TextBlock
                    Foreground="White"
                    Text="{Binding SelectedSquareText}"/>

            </Border>

            <Separator/>

            <TextBlock
                FontSize="18"
                Text="Last Move"/>

            <Border
                Padding="10"
                CornerRadius="6"
                Background="#404040">

                <TextBlock
                    Foreground="White"
                    Text="{Binding LastMoveText}"/>

            </Border>

            <Separator/>

            <Separator/>
                <TextBlock
                    FontSize="18"
                    Text="Game Status"/>

                <Border
                    Padding="10"
                    CornerRadius="6"
                    Background="#404040">

                    <TextBlock
                        Foreground="White"
                        FontWeight="Bold"
                        Text="{Binding GameStatusText}"/>

                </Border>

            <Button
                Width="180"
                Height="48"
                FontSize="18"
                FontWeight="Bold"
                Content="Restart Game"/>

        </StackPanel>

    </Grid>

</Window>