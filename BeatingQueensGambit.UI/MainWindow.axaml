<Window
    x:Class="BeatingQueensGambit.UI.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:BeatingQueensGambit.UI.ViewModels"
    x:DataType="viewModels:ChessViewModel"
    Width="1450"
    Height="980"
    Title="Beating Queen's Gambit">

    <Grid
        ColumnDefinitions="3*,1*"
        RowDefinitions="*">

        <!-- ========================= -->
        <!-- Chess Board -->
        <!-- ========================= -->

        <Border
            Grid.Column="0"
            Margin="30"
            Padding="8"
            Background="#252525"
            BorderBrush="#404040"
            BorderThickness="3"
            CornerRadius="8">

            <ItemsControl ItemsSource="{Binding Squares}">

                <ItemsControl.ItemsPanel>

                    <ItemsPanelTemplate>

                        <UniformGrid
                            Rows="8"
                            Columns="8"/>

                    </ItemsPanelTemplate>

                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>

                    <DataTemplate
                        x:DataType="viewModels:SquareViewModel">

                        <Border
                            Background="{Binding SquareColor}"
                            PointerPressed="SquarePressed">

                            <Image
                                Margin="10"
                                Stretch="Uniform"
                                Source="{Binding PieceImage}"/>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </Border>

        <!-- ========================= -->
        <!-- Right Panel -->
        <!-- ========================= -->

        <ScrollViewer
            Grid.Column="1"
            Margin="20">

            <StackPanel
                Spacing="14">

                <TextBlock
                    FontSize="28"
                    FontWeight="Bold"
                    Text="Beating Queen's Gambit"/>

                <Separator/>

                <!-- Current Turn -->

                <TextBlock
                    FontSize="18"
                    Text="Current Turn"/>

                <Border
                    Background="#404040"
                    CornerRadius="6"
                    Padding="10">

                    <TextBlock
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="{Binding CurrentTurnText}"/>

                </Border>

                <Separator/>

                <!-- Game Status -->

                <TextBlock
                    FontSize="18"
                    Text="Game Status"/>

                <Border
                    Background="#404040"
                    CornerRadius="6"
                    Padding="10">

                    <TextBlock
                        FontWeight="Bold"
                        Foreground="White"
                        Text="{Binding GameStatusText}"/>

                </Border>

                <Separator/>

                <!-- Selected Square -->

                <TextBlock
                    FontSize="18"
                    Text="Selected Square"/>

                <Border
                    Background="#404040"
                    CornerRadius="6"
                    Padding="10">

                    <TextBlock
                        Foreground="White"
                        Text="{Binding SelectedSquareText}"/>

                </Border>

                <Separator/>

                <!-- Last Move -->

                <TextBlock
                    FontSize="18"
                    Text="Last Move"/>

                <Border
                    Background="#404040"
                    CornerRadius="6"
                    Padding="10">

                    <TextBlock
                        Foreground="White"
                        Text="{Binding LastMoveText}"/>

                </Border>

                <Separator/>

                <!-- Move History -->

                <TextBlock
                    FontSize="18"
                    Text="Move History"/>

                <Border
                    Background="#404040"
                    CornerRadius="6"
                    Padding="8"
                    Height="250">

                    <ScrollViewer>

                        <ItemsControl
                            ItemsSource="{Binding MoveHistory}">

                            <ItemsControl.ItemTemplate>

                                <DataTemplate>

                                    <TextBlock
                                        Margin="0,3"
                                        FontSize="16"
                                        Foreground="White"
                                        Text="{Binding}"/>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </ScrollViewer>

                </Border>

                <Separator/>

                <Button
                    Width="200"
                    Height="50"
                    FontSize="18"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    Content="Restart Game"/>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</Window>